# API Keys (server-side only - NOT exposed to client)
# Copy this file to .env and fill in your actual API keys

ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL (used for OAuth redirects and email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Allowed emails (comma-separated) - only these users can log in
# Example: user1@gmail.com,user2@gmail.com,user3@gmail.com
ALLOWED_EMAILS=

# Admin emails (comma-separated) - these users get admin role on login
ADMIN_EMAILS=

# Allowed hosts for redirect validation (comma-separated)
ALLOWED_HOSTS=localhost:3000

# Email for admin notifications (signup requests, etc.)
ADMIN_NOTIFICATION_EMAIL=

# Resend API key for sending emails (signup notifications)
RESEND_API_KEY=
